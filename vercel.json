{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix david-portfolio install",
  "buildCommand": "npm --prefix david-portfolio run build",
  "outputDirectory": "david-portfolio/dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.davidgeha.dev" }],
      "destination": "https://davidgeha.dev/:path*",
      "permanent": true
    }
  ]
}
